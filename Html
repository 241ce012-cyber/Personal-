<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Personal Portfolio</title>

    <link rel="stylesheet"
          href="style.css">

</head>

<body style="background-color: antiquewhite;">

    <!-- Navbar -->

    <nav>

        <h1 class="logo">Portfolio</h1>

        <ul>

            <li><a href="#home">Home</a></li>

            <li><a href="#about">About</a></li>

            <li><a href="#projects">Projects</a></li>

            <li><a href="#contact">Contact</a></li>

        </ul>

    </nav>

    <!-- Home Section -->

    <section id="home" class="home">

        <div class="home-text">

            <h2 style="color:black;">Hello, I'm</h2>

            <h1 style="color:palevioletred;">PRITHIKA G</h1>

            <p style="color: black;">Full Stack Developer</p>

            <button style="background-color: palevioletred;">Hire Me</button>

        </div>

    </section>

    <!-- About Section -->

    <section id="about" class="about">

        <h2 style="color:palevioletred">About Me</h2>

        <p>

            I am a passionate web developer
            interested in frontend and backend
            development.

        </p>

    </section>

    <!-- Project Section -->

    <section id="projects" class="projects">

        <h2 style="color: palevioletred;">My Projects</h2>

        <div class="project-box">

            <h3>Portfolio Website</h3>

            <p>HTML CSS JavaScript Project</p>

        </div>

        <div class="project-box">

            <h3>Login System</h3>

            <p>Node.js and MongoDB Project</p>

        </div>

    </section>

    <!-- Contact Section -->

    <section id="contact" class="contact">

        <h2 style="color: palevioletred;">Contact Me</h2>

        <form>

            <input type="text"
                   placeholder="Enter Name">

            <input type="email"
                   placeholder="Enter Email">

            <input type="contact number"
                placeholder="Enter contact number">

            <button type="submit">
                Send
            </button>

        </form>

    </section>

    <script src="script.js"></script>

</body>

</html>
